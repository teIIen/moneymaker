# Базовый файл .gitignore для Python проекта
__pycache__/
*.py[cod]
*$py.class

# Виртуальные окружения
venv/
env/
.env

# Логи и базы данных
*.log
logs/
*.sqlite3

# Секреты и конфигурации
config/settings.py

# Конфигурации IDE
.idea/
.vscode/

# Jupyter (если вдруг понадобится для тестов)
.ipynb_checkpoints
